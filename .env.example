SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
DATABASE_URL=postgresql://postgres:password@your-project.supabase.co:5432/postgres
GEMINI_API_KEY=your-gemini-key
TELEGRAM_BOT_TOKEN=your-telegram-token
# Security — Telegram webhook verification
# TELEGRAM_WEBHOOK_SECRET=your-secret-token
# Security — Service role key (bypasses RLS for backend)
# SUPABASE_SERVICE_KEY=your-service-role-key
# Security — Secret for signing dashboard session JWTs
SESSION_SECRET=generate-a-random-string-here

# Obsidian vault path — folder where .md files are written
# OBSIDIAN_VAULT_PATH=C:/Users/you/Obsidian/Grain
# NITTER_INSTANCE=nitter.net           # X.com fallback scraping instance
